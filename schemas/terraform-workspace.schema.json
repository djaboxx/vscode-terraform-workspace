{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://happypathway.com/schemas/terraform-workspace.schema.json",
  "title": "Terraform Workspace Config",
  "description": "Configuration file for the VS Code Terraform Workspace extension. Binds a workspace folder to a GitHub repo. Use 'environments' for GHA-Environment-backed repos, or 'workspaces' for flat repos without GHA Environments.",
  "type": "object",
  "required": ["version", "repo"],
  "oneOf": [
    { "required": ["environments"] },
    { "required": ["workspaces"] }
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Currently always 1."
    },
    "compositeActionOrg": {
      "type": "string",
      "description": "GitHub org that owns the composite action repos."
    },
    "terraformVersion": {
      "type": "string",
      "description": "Default Terraform/OpenTofu version. Falls back to the `terraform_version` GitHub Actions variable when not set."
    },
    "awsAuthMode": {
      "type": "string",
      "enum": ["oidc", "access-keys", "profile", "none"],
      "default": "oidc",
      "description": "AWS auth mode for generated workflows. `oidc` (default) requires AWS_ROLE_TO_ASSUME + IAM trust. `access-keys` uses AWS_ACCESS_KEY_ID/SECRET secrets (optionally still assumes a role). `profile` uses a self-hosted runner's pre-configured profile/instance role. `none` skips AWS auth entirely."
    },
    "executor": {
      "type": "string",
      "enum": ["inline", "codebuild"],
      "default": "inline",
      "description": "Where the heavy `terraform plan/apply` runs. `inline` (default) runs on the GHA runner that picked up the job. `codebuild` makes the GHA job an orchestrator that uploads the repo to S3, calls `aws codebuild start-build`, tails logs, and downloads the plan back. Per-env `executor` overrides this."
    },
    "codebuild": { "$ref": "#/definitions/codebuild" },
    "proxy": {
      "type": "object",
      "additionalProperties": false,
      "description": "HTTP(S) proxy passthrough emitted on every workflow step.",
      "properties": {
        "http": { "type": "string" },
        "https": { "type": "string" },
        "no": { "type": "string" }
      }
    },
    "repo": { "$ref": "#/definitions/repo" },
    "useGhaEnvironments": {
      "type": "boolean",
      "default": true,
      "description": "Set to false for flat repos that do not use GitHub Actions Environments. When false the generated workflows omit the 'environment:' gating block and environment-scoped secrets/variables are not fetched. Use 'workspaces' instead of 'environments' in this case."
    },
    "environments": {
      "type": "array",
      "description": "List of GitHub Actions Environments (= Terraform workspaces). Use this for repos that have GHA Environments configured. Mutually exclusive with 'workspaces'.",
      "minItems": 1,
      "items": { "$ref": "#/definitions/environment" }
    },
    "workspaces": {
      "type": "array",
      "description": "List of Terraform workspace run-configurations for flat repos that do not use GHA Environments. Each entry generates a plan/apply workflow pair. Mutually exclusive with 'environments'.",
      "minItems": 1,
      "items": { "$ref": "#/definitions/environment" }
    },
    "stateConfig": { "$ref": "#/definitions/stateConfig" },
    "compositeActions": { "$ref": "#/definitions/compositeActions" }
  },
  "definitions": {
    "repo": {
      "type": "object",
      "required": ["name", "repoOrg"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "Repo name (no org prefix)." },
        "repoOrg": { "type": "string", "description": "GitHub org or user that owns the repo." },
        "description": { "type": "string" },
        "createRepo": { "type": "boolean" },
        "isPrivate": { "type": "boolean" },
        "isTemplate": { "type": "boolean" },
        "templateRepoOrg": { "type": "string" },
        "templateRepo": { "type": "string" },
        "enforcePrs": { "type": "boolean" },
        "createCodeowners": { "type": "boolean" },
        "codeownersTeam": { "type": "string" },
        "adminTeams": { "type": "array", "items": { "type": "string" } },
        "pullRequestBypassers": { "type": "array", "items": { "type": "string" } },
        "repoTopics": { "type": "array", "items": { "type": "string" } },
        "archiveOnDestroy": { "type": "boolean" },
        "vars": { "type": "array", "items": { "$ref": "#/definitions/nameValue" } },
        "secrets": { "type": "array", "items": { "$ref": "#/definitions/nameValue" } }
      }
    },
    "environment": {
      "type": "object",
      "required": ["name", "cacheBucket"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "GitHub Environment name (= terraform workspace name)." },
        "cacheBucket": { "type": "string", "description": "S3 bucket used for plan/apply artifact caching." },
        "runnerGroup": { "type": "string" },
        "executor": {
          "type": "string",
          "enum": ["inline", "codebuild"],
          "description": "Per-env override of the top-level `executor`."
        },
        "codebuild": { "$ref": "#/definitions/codebuild" },
        "preventSelfReview": { "type": "boolean" },
        "waitTimer": { "type": "integer", "minimum": 0, "maximum": 43200 },
        "canAdminsBypass": { "type": "boolean" },
        "terraformVersion": { "type": "string", "description": "Per-environment Terraform/OpenTofu version pin." },
        "varfile": { "type": "string", "description": "Path to per-env tfvars file (default: varfiles/<env>.tfvars)." },
        "reviewers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "users": { "type": "array", "items": { "type": "string" } },
            "teams": { "type": "array", "items": { "type": "string" } },
            "enforceReviewers": { "type": "boolean" }
          }
        },
        "deploymentBranchPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "branch": { "type": "string" },
            "branchPattern": { "type": "string" },
            "createBranch": { "type": "boolean" },
            "createBranchProtection": { "type": "boolean" },
            "protectedBranches": { "type": "boolean" },
            "customBranchPolicies": { "type": "boolean" },
            "enforceAdmins": { "type": "boolean" },
            "restrictBranches": { "type": "boolean" },
            "requiredStatusChecks": {
              "type": "object",
              "additionalProperties": false,
              "required": ["contexts"],
              "properties": {
                "strict": { "type": "boolean" },
                "contexts": { "type": "array", "items": { "type": "string" } }
              }
            },
            "requiredPullRequestReviews": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "dismissStaleReviews": { "type": "boolean" },
                "requireCodeOwnerReviews": { "type": "boolean" },
                "requiredApprovingReviewCount": { "type": "integer", "minimum": 0, "maximum": 6 }
              }
            }
          }
        },
        "stateConfig": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bucket": { "type": "string" },
            "keyPrefix": { "type": "string" },
            "region": { "type": "string" },
            "dynamodbTable": { "type": "string" },
            "setBackend": { "type": "boolean" }
          }
        },
        "vars": { "type": "array", "items": { "$ref": "#/definitions/nameValue" } },
        "secrets": { "type": "array", "items": { "$ref": "#/definitions/nameValue" } }
      }
    },
    "stateConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bucket": { "type": "string" },
        "key": { "type": "string" },
        "region": { "type": "string" },
        "dynamodbTable": { "type": "string" },
        "setBackend": { "type": "boolean" },
        "keyPrefix": { "type": "string" }
      }
    },
    "compositeActions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checkout": { "type": "string" },
        "awsAuth": { "type": "string" },
        "setupTerraform": { "type": "string" },
        "terraformInit": { "type": "string" },
        "terraformPlan": { "type": "string" },
        "terraformApply": { "type": "string" },
        "ghAuth": { "type": "string" },
        "s3Cleanup": { "type": "string" }
      }
    },
    "nameValue": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
        "value": { "type": "string" }
      }
    },
    "codebuild": {
      "type": "object",
      "required": ["project", "sourceBucket"],
      "additionalProperties": false,
      "description": "AWS CodeBuild dispatch settings used when executor=codebuild. The GHA orchestrator uploads a zip of the repo to sourceBucket, calls codebuild:StartBuild on `project`, tails CloudWatch logs, and downloads the plan artifact back from artifactBucket (defaults to sourceBucket).",
      "properties": {
        "project": { "type": "string", "description": "CodeBuild project name (must already exist; provision via the scaffolder)." },
        "sourceBucket": { "type": "string", "description": "S3 bucket the GHA job uploads the repo zip to (= the project's S3 source)." },
        "artifactBucket": { "type": "string", "description": "S3 bucket the buildspec writes plan artifacts to. Defaults to sourceBucket." },
        "region": { "type": "string", "description": "AWS region of the CodeBuild project. Falls back to AWS_REGION env in the workflow." }
      }
    }
  }
}
